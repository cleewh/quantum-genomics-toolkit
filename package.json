{
  "name": "quantum-genomics-pipeline",
  "version": "0.1.0",
  "description": "Quantum Genomics Encoding Pipeline - Encodes genomic sequences into quantum circuits for execution on Amazon Braket",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "quantum-encode": "./dist/toolkit/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-braket": "^3.700.0",
    "@aws-sdk/client-kms": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "fast-check": "^3.23.0",
    "tsx": "^4.22.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
